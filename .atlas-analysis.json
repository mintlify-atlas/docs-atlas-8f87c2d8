  "keyFeatures": [
    "Interactive campus map with route visualization",
    "AI-powered chatbot assistant for student queries",
    "User authentication and profile management",
    "Scholarship and academic services information",
    "Real-time campus navigation with search functionality",
    "Student services integration (medical, social, CID)",
    "Multi-language support and customizable profiles",
    "Offline map caching and route storage"
  ],
  "publicApiSurface": [
    "POST /api/login - User authentication",
    "POST /api/register - User registration",
    "GET /api/user/profile - Get user profile",
    "PUT /api/user/profile - Update user profile",
    "GET /api/campus/locations - Get campus locations",
    "GET /api/routes - Get navigation routes",
    "POST /api/chatbot/query - Send chatbot message",
    "GET /api/scholarships - Get scholarship information",
    "GET /api/services - Get campus services data"
  ]
